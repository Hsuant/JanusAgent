# LLM API Configuration
# Provider: openai, anthropic, azure, custom or local

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Configuration (if using Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Local LLM Configuration (Ollama / vLLM compatible)
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
LOCAL_MODEL_API_KEY=not-needed

# Custom
CUSTOMIZE_BASE_URL=your-custom-base-url-here
CUSTOMIZE_API_KEY=your-custom-api-key-here

# Agent Configuration
AGENT_MAX_ITERATIONS=10
AGENT_MAX_TOOL_CALLS_PER_TASK=20
AGENT_RECURSION_LIMIT=25

# Memory Configuration
MEMORY_SHORT_TERM_MAX_MESSAGES=50
MEMORY_VECTOR_STORE_TYPE=chroma
MEMORY_VECTOR_STORE_PATH=./data/chroma_db

# MCP Configuration
MCP_SERVERS_CONFIG_PATH=./config/mcp_servers.yaml
MCP_CONNECTION_TIMEOUT=30
MCP_TOOL_CALL_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
LOG_FORMAT=json